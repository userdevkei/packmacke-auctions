{
    "name": "laravel/laravel",
    "type": "project",
    "description": "The skeleton application for the Laravel framework.",
    "keywords": [
        "laravel",
        "framework"
    ],
    "license": "MIT",
    "require": {
        "php": "^8.1|^8.2|^8.3|^8.4",
        "barryvdh/laravel-dompdf": "^v3.1.2",
        "dompdf/dompdf": "^v3.1.5",
        "guzzlehttp/guzzle": "^7.13.1",
        "intervention/image": "*",
        "intervention/image-laravel": "^1.5.9",
        "laravel/framework": "^v13.17.0",
        "laravel/sanctum": "^v4.3.2",
        "laravel/tinker": "^v3.0.2",
        "mpdf/mpdf": "^v8.3.1",
        "ncjoes/office-converter": "^1.0.8",
        "nwidart/laravel-modules": "v13.0.0",
        "phpoffice/phpspreadsheet": "^1.30.0",
        "maatwebsite/excel": "^3.1.68",
        "phpoffice/phpword": "^1.4.0",
        "simplesoftwareio/simple-qrcode": "^4.2.0",
        "spatie/laravel-pdf": "^2.12.0",
        "spatie/pdf-to-image": "^1.2.2",
        "tecnickcom/tcpdf": "^6.11.3"
    },
    "require-dev": {
        "fakerphp/faker": "^v1.24.1",
        "laravel/pint": "^v1.29.3",
        "laravel/sail": "^v1.63.0",
        "mockery/mockery": "^1.6.12",
        "nunomaduro/collision": "^v8.9.4",
        "phpunit/phpunit": "^11.5.55",
        "spatie/laravel-ignition": "^2.12.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Modules\\": "Modules/"
        },
        "files": [
            "app/Helpers/ClerkPermissionsHelper.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true,
            "wikimedia/composer-merge-plugin": true
        },
        "audit": {
            "block-insecure": false
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
